# Listing of Parameters
# ---------------------
# Number of dimensions

set dimension = 3
set run_type = integration_test
set test_type = euler_entropy_conserving_split_forms_check
set pde_type = euler

# DG formulation
set use_weak_form = false
set use_split_form = true
set flux_nodes_type = GLL

set flux_reconstruction = cDG
set use_inverse_mass_on_the_fly = true

set all_boundaries_are_periodic = true
set check_same_coords_in_weak_dg = false

# numerical fluxes
set conv_num_flux = two_point_flux
# two_point_num_flux_type is set by the test

subsection mesh adaptation
    set total_mesh_adaptation_cycles = 1
    set use_goal_oriented_mesh_adaptation = false
    set mesh_adaptation_type = p_adaptation
    subsection fixed-fraction
      set refine_fraction = 0.5
      set h_coarsen_fraction = 0.0
    end
end

# ODE solver
subsection ODE solver
  set ode_output = quiet
  set ode_solver_type = runge_kutta
  set runge_kutta_method = rk4_ex
  set output_solution_every_dt_time_intervals = 1.0E-2
end

# freestream Mach number
subsection euler
  set mach_infinity = 0.1
end

subsection flow_solver
  set flow_case_type = taylor_green_vortex
  set poly_degree = 1
  set max_poly_degree_for_adaptation = 2
  set final_time = 0.1
  set courant_friedrichs_lewy_number = 0.005
  set unsteady_data_table_filename = tgv_kinetic_energy_vs_time_table
  subsection grid
    # set grid_left_bound = 0.0
    # set grid_right_bound = 6.28318530717958623200
    # set number_of_grid_elements_per_dimension = 4

    set grid_left_bound = 0.0
    set grid_right_bound = 6.28318530717958623200
    set input_mesh_filename = ../../meshes/3d_cube_periodic
    set use_gmsh_mesh = true
    subsection gmsh_boundary_IDs
      set use_periodic_BC_in_x = true
      set use_periodic_BC_in_y = true
      set use_periodic_BC_in_z = true
      set x_periodic_id_face_1 = 2001
      set x_periodic_id_face_2 = 2002
      set y_periodic_id_face_1 = 2003
      set y_periodic_id_face_2 = 2004
      set z_periodic_id_face_1 = 2005
      set z_periodic_id_face_2 = 2006
    end
  end
  subsection taylor_green_vortex
    set do_calculate_numerical_entropy = true
    set density_initial_condition_type = isothermal
  end
end
